# Copy to .env.local and fill in your values from the Supabase project dashboard:
# https://supabase.com/dashboard/project/<your-project>/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Comma-separated Supabase user UUIDs that get admin privileges on the blog
DOCUSAURUS_ADMIN_USER_ID=uuid1,uuid2

# Cloudflare R2 image uploads — used by `npm run upload-image` (S3-compatible API)
# Account ID: Cloudflare dashboard -> R2 -> right sidebar "Account ID"
CLOUDFLARE_ACCOUNT_ID=your-account-id
# S3 credentials: shown ONCE on the R2 API token creation page, under the
#   "Use the following credentials for S3 clients" section
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
# The R2 bucket NAME (not the public cdn domain)
R2_BUCKET=your-bucket-name
# Public base URL that serves the bucket (your custom domain)
R2_PUBLIC_BASE=https://cdn.mikeq95blog.uk
