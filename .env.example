# Copy to .env.local and fill in your values from the Supabase project dashboard:
# https://supabase.com/dashboard/project/<your-project>/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Comma-separated Supabase user UUIDs that get admin privileges on the blog
DOCUSAURUS_ADMIN_USER_ID=uuid1,uuid2
